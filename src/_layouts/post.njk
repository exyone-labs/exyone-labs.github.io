---
layout: base.njk
---
{# ================================================================
   Post Detail Layout (Template Layer)
   Article page with TOC on top, enhanced metadata, related posts,
   prev/next navigation, and comments section.
   ================================================================ #}
{% include "left-nav.njk" %}

<main class="main-content" id="main-content">
  <article class="post-detail">
    <!-- Article header -->
    <header class="post-detail__header">
      <!-- Title row: categories + title on the same line -->
      <div class="post-detail__title-row">
        <h1 class="post-detail__title">{{ title }}</h1>
        {% if categories %}
          <div class="post-detail__categories">
            {% for cat in categories %}
              <a href="/categories/{{ cat | slugify }}/" class="category-badge">{{ cat }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Tag badges -->
      {% if tags %}
        <div class="post-detail__tags mb-3">
          {% for tag in tags %}
            <a href="/tags/{{ tag | slugify }}/" class="tag-badge">#{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <!-- Post metadata -->
      <div class="post-detail__meta">
        <span class="post-detail__date">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          发布于 {{ date | readableDate }}
        </span>
        {% if updated %}
          <span class="post-detail__date">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
            更新于 {{ updated | readableDate }}
          </span>
        {% endif %}
        {% if site.showReadingTime %}
        <span class="post-detail__reading-time">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {{ content | readingTime }} 分钟阅读
        </span>
        {% endif %}
        {% if site.showWordCount %}
        <span class="post-detail__word-count">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          {{ content | wordCount }} 字
        </span>
        {% endif %}
      </div>
    </header>

    <!-- ============================================================ -->
    <!--  Excerpt                                                      -->
    <!-- ============================================================ -->
    {% if excerpt %}
      <div class="post-detail__excerpt">{{ excerpt }}</div>
    {% endif %}

    <!-- ============================================================ -->
    <!--  Article Content                                              -->
    <!-- ============================================================ -->
    <div class="post-detail__content">
      {{ content | safe }}
    </div>

    <!-- ============================================================ -->
    <!--  Article Footer (Tags)                                        -->
    <!-- ============================================================ -->
    <footer class="post-detail__footer">
      {% if tags %}
        <div class="post-detail__footer-tags">
          {% for tag in tags %}
            <a href="/tags/{{ tag | slugify }}/" class="tag-badge">#{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </footer>
  </article>

  <!-- ============================================================ -->
  <!--  Prev / Next Post Navigation — Same Line                     -->
  <!-- ============================================================ -->
  {% set allPosts = collections.posts %}
  {% set prevPost = allPosts | prevPost(page.url) %}
  {% set nextPost = allPosts | nextPost(page.url) %}
  <nav class="post-nav">
    {% if prevPost %}
      <a href="{{ prevPost.url }}" class="post-nav-link post-nav-link--prev">
        <span class="post-nav-direction">
          <span class="post-nav-arrow">←</span>
          上一篇
        </span>
        <span class="post-nav-title">{{ prevPost.data.title }}</span>
      </a>
    {% else %}
      <div class="post-nav-link post-nav-link--prev post-nav-link--disabled">
        <span class="post-nav-direction">
          <span class="post-nav-arrow">←</span>
          上一篇
        </span>
        <span class="post-nav-title">暂无更多文章</span>
      </div>
    {% endif %}
    {% if nextPost %}
      <a href="{{ nextPost.url }}" class="post-nav-link post-nav-link--next">
        <span class="post-nav-direction">
          下一篇
          <span class="post-nav-arrow">→</span>
        </span>
        <span class="post-nav-title">{{ nextPost.data.title }}</span>
      </a>
    {% else %}
      <div class="post-nav-link post-nav-link--next post-nav-link--disabled">
        <span class="post-nav-direction">
          下一篇
          <span class="post-nav-arrow">→</span>
        </span>
        <span class="post-nav-title">暂无更多文章</span>
      </div>
    {% endif %}
  </nav>

  <!-- ============================================================ -->
  <!--  Related Posts                                                -->
  <!-- ============================================================ -->
  {% if site.showRelatedPosts and collections.posts.length > 1 %}
  <section class="related-posts">
    <h2 class="related-posts__title">相关文章</h2>
    <div class="related-posts__grid">
      {% set related = collections.posts | relatedPosts(page.url, site.maxRelatedPosts) %}
      {% for relatedPost in related %}
      <a href="{{ relatedPost.url }}" class="related-post-card">
        <h3 class="related-post-card__title">{{ relatedPost.data.title }}</h3>
        <div class="related-post-card__meta">
          <span>{{ relatedPost.date | readableDate }}</span>
          <span>·</span>
          <span>{{ relatedPost.templateContent | readingTime }} 分钟阅读</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- ============================================================ -->
  <!--  Comments Section (Giscus)                                   -->
  <!-- ============================================================ -->
  {% if comments.provider == "giscus" and comments.giscus.repo %}
  <section class="comments-section" id="comments">
    <h2 class="comments-section__title">评论</h2>
    <script src="https://giscus.app/client.js"
      data-repo="{{ comments.giscus.repo }}"
      data-repo-id="{{ comments.giscus.repo_id }}"
      data-category="{{ comments.giscus.category }}"
      data-category-id="{{ comments.giscus.category_id }}"
      data-mapping="{{ comments.giscus.mapping }}"
      data-strict="{{ comments.giscus.strict }}"
      data-reactions-enabled="{{ comments.giscus.reactions_enabled }}"
      data-emit-metadata="0"
      data-input-position="{{ comments.giscus.input_position }}"
      data-lang="{{ site.lang }}"
      data-loading="lazy"
      crossorigin="anonymous"
      async>
    </script>
  </section>
  {% elseif comments.provider == "twikoo" and comments.twikoo.env_id %}
  <section class="comments-section" id="comments">
    <h2 class="comments-section__title">评论</h2>
    <div id="twikoo-comments"></div>
    <script src="https://cdn.jsdelivr.net/npm/twikoo@{{ comments.twikoo.version }}/dist/twikoo.all.min.js"></script>
    <script>twikoo.init({ envId: '{{ comments.twikoo.env_id }}', el: '#twikoo-comments' });</script>
  </section>
  {% endif %}
</main>

{% include "right-sidebar.njk" %}
