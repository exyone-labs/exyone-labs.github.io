{# ================================================================
   "关于我" 侧边栏组件 (About Sidebar Card)
   Usage: {% include "about-sidebar.njk" %}
   Place this inside a .col-lg-4 or sidebar container.
   ================================================================ #}
<div class="card about-card border-0 mb-4">
  <div class="card-body text-center px-4 pt-4 pb-3">
    <!-- Circular Avatar -->
    <div class="about-avatar-wrapper mx-auto mb-3">
      <img src="{{ author.avatar }}" alt="{{ author.name }}" class="about-avatar rounded-circle" width="88" height="88" loading="lazy">
    </div>

    <!-- Nickname -->
    <h5 class="about-name fw-bold mb-1" style="color: #222;">
      {{ author.name }}
    </h5>

    <!-- Tagline / Short Bio -->
    <p class="about-tagline text-muted small mb-3" style="color: #6c757d !important; font-size: 0.85rem;">
      {{ author.description or site.tagline }}
    </p>

    <hr class="about-divider mx-auto" style="width: 36px; opacity: 0.25; margin: 0.75rem auto;">

    <!-- Recent Posts List -->
    <div class="about-recent text-start">
      <p class="about-recent-title fw-semibold small mb-2" style="color: #555; font-size: 0.78rem; letter-spacing: 0.03em; text-transform: uppercase;">
        <i class="fas fa-clock me-1" style="font-size: 0.7rem;"></i> 最近文章
      </p>
      <ul class="list-unstyled mb-0 about-recent-list" style="font-size: 0.85rem;">
        {% set recentPosts = collections.posts | reverse | slice(0, 5) %}
        {%- for post in recentPosts %}
        <li class="about-recent-item mb-1">
          <a href="{{ post.url }}" class="about-recent-link text-decoration-none d-block py-1 px-2 rounded">
            <i class="fas fa-leaf me-1" style="font-size: 0.55rem; color: #4CAF50;"></i>
            {{ post.data.title }}
          </a>
        </li>
        {%- endfor %}
      </ul>
    </div>
  </div>

  <!-- Footer: Social Icons -->
  <div class="card-footer border-0 bg-transparent text-center pb-3 pt-0">
    <div class="d-flex justify-content-center gap-2">
      {% if author.social.github %}
        <a href="{{ author.social.github }}" class="about-social-link" aria-label="GitHub" target="_blank" rel="noopener">
          <i class="fab fa-github fa-lg"></i>
        </a>
      {% endif %}
      {% if author.social.twitter %}
        <a href="{{ author.social.twitter }}" class="about-social-link" aria-label="Twitter" target="_blank" rel="noopener">
          <i class="fab fa-twitter fa-lg"></i>
        </a>
      {% endif %}
      {% if author.social.email %}
        <a href="{{ author.social.email }}" class="about-social-link" aria-label="Email">
          <i class="fas fa-envelope fa-lg"></i>
        </a>
      {% endif %}
      {% if author.social.weibo %}
        <a href="{{ author.social.weibo }}" class="about-social-link" aria-label="Weibo" target="_blank" rel="noopener">
          <i class="fab fa-weibo fa-lg"></i>
        </a>
      {% endif %}
    </div>
  </div>
</div>
