{# ================================================================
   Site Footer (Template Layer - Component)
   Copyright and attribution footer with social links.
   ================================================================ #}
<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__copyright">
      &copy; {{ "now" | year }} <a href="{{ author.social.github }}">{{ author.name }}</a>. 保留所有权利。
    </p>
    <div class="site-footer__links">
      {% if author.social.twitter %}
        <a href="{{ author.social.twitter }}" class="site-footer__link" aria-label="Twitter" target="_blank" rel="noopener">
          <i class="fab fa-twitter"></i>
        </a>
      {% endif %}
      {% if author.social.github %}
        <a href="{{ author.social.github }}" class="site-footer__link" aria-label="GitHub" target="_blank" rel="noopener">
          <i class="fab fa-github"></i>
        </a>
      {% endif %}
      {% if author.social.email %}
        <a href="{{ author.social.email }}" class="site-footer__link" aria-label="Email">
          <i class="fas fa-envelope"></i>
        </a>
      {% endif %}
      <span class="site-footer__powered">
        Powered by <a href="https://www.11ty.dev/" target="_blank" rel="noopener">Eleventy</a>
      </span>
    </div>
  </div>
</footer>
