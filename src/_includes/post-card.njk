{# ================================================================
   Post Card (Template Layer - Component)
   Reusable card component for displaying post summaries in list views.
   Usage: {% include "post-card.njk" %}
   Requires: `post` variable in context.
   ================================================================ #}
<article class="post-card">
  <div class="post-card__body">
    <!-- Title row: categories + title on the same line -->
    <div class="post-card__title-row">
      <h2 class="post-card__title">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </h2>
      {% if post.data.categories %}
        <div class="post-card__categories">
          {% for cat in post.data.categories %}
            <a href="/categories/{{ cat | slugify }}/" class="category-badge">{{ cat }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Post excerpt -->
    <p class="post-card__excerpt">
      {{ post.data.excerpt or '' }}
    </p>

    <!-- Post metadata -->
    <div class="post-card__meta">
      <span class="post-card__date">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        {{ post.date | readableDate }}
      </span>

      <!-- Tag badges -->
      {% if post.data.tags %}
        <div class="post-card__tags">
          {% for tag in post.data.tags %}
            <a href="/tags/{{ tag | slugify }}/" class="tag-badge">#{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</article>
