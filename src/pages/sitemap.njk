---
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Home page -->
  <url>
    <loc>{{ site.url }}/</loc>
    <lastmod>{{ collections.posts[0].date | dateToRfc3339 }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Categories overview -->
  <url>
    <loc>{{ site.url }}/categories/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Tags overview -->
  <url>
    <loc>{{ site.url }}/tags/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Archive -->
  <url>
    <loc>{{ site.url }}/archive/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- Category pages -->
{% for cat in collections.categories %}
  <url>
    <loc>{{ site.url }}/categories/{{ cat.slug }}/</loc>
    <lastmod>{{ cat.posts[0].date | dateToRfc3339 }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
{% endfor %}

  <!-- Tag pages -->
{% for tag in collections.tagList %}
  <url>
    <loc>{{ site.url }}/tags/{{ tag.slug }}/</loc>
    <lastmod>{{ tag.posts[0].date | dateToRfc3339 }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.5</priority>
  </url>
{% endfor %}

  <!-- Post pages -->
{% for post in collections.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | dateToRfc3339 }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
{% endfor %}
</urlset>
