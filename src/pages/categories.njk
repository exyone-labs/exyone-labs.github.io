{# ================================================================
   Categories Overview Page (Template Layer)
   Displays all categories in a grid layout with post counts.
   ================================================================ #}
{% include "left-nav.njk" %}

<main class="main-content" id="main-content">
  <section class="categories-grid">
    {% for cat in collections.categories %}
      <a href="/categories/{{ cat.slug }}/" class="category-card">
        <h2 class="category-card__name">{{ cat.name }}</h2>
        <span class="category-card__count">{{ cat.posts.length }} 篇文章</span>
      </a>
    {% endfor %}
  </section>
</main>

