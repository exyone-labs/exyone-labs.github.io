{# ================================================================
   Tags Overview Page (Template Layer)
   Displays all tags as a weighted tag cloud.
   ================================================================ #}
{% include "left-nav.njk" %}

<main class="main-content" id="main-content">
  <section class="tags-page">
    {% for tag in collections.tagList %}
      <a href="/tags/{{ tag.slug }}/" class="tags-page__item" data-count="{{ tag.posts.length }}">
        #{{ tag.name }}<span class="tags-page__count">{{ tag.posts.length }}</span>
      </a>
    {% endfor %}
  </section>
</main>

