---
layout: base.njk
title: 首页
permalink: /
pagination:
  data: collections.posts
  size: 8
  alias: posts
  reverse: true
---
{# ================================================================
   Home Page (Template Layer)
   Displays the latest blog posts with pagination.
   ================================================================ #}
{% include "left-nav.njk" %}

<main class="main-content" id="main-content">
  <section class="post-list">
    {% for post in pagination.items %}
      {% include "post-card.njk" %}
    {% endfor %}
  </section>

  {% if pagination.hrefs.length > 1 %}
  <nav class="pagination" aria-label="分页导航">
    {% if pagination.previousPageLink %}
      <a href="{{ pagination.previousPageLink }}" class="pagination__item pagination__item--prev">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        上一页
      </a>
    {% endif %}

    {% for href in pagination.hrefs %}
      {% if loop.index == pagination.currentPage %}
        <span class="pagination__item pagination__item--active">{{ loop.index }}</span>
      {% else %}
        <a href="{{ href }}" class="pagination__item">{{ loop.index }}</a>
      {% endif %}
    {% endfor %}

    {% if pagination.nextPageLink %}
      <a href="{{ pagination.nextPageLink }}" class="pagination__item pagination__item--next">
        下一页
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    {% endif %}
  </nav>
  {% endif %}
</main>

{% include "right-sidebar.njk" %}
